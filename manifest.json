{
  "manifest_version": 3,
  "name": "Doomscroll Blocker",
  "version": "2.0.0",
  "description": "Block doomscrolling on YouTube and track your consumption stats",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["core/test-bridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": [
        "core/storage.js",
        "core/time-tracker.js",
        "core/degradation-engine.js",
        "core/blocking-engine.js",
        "core/stats-widget.js",
        "core/sync-client.js",
        "adapters/youtube.js",
        "core/content-main.js"
      ],
      "css": [
        "styles/base.css",
        "styles/degradation.css",
        "styles/youtube.css"
      ],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*.svg", "icons/*.png", "icons/*.jpg"],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
