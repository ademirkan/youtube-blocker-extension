{
  "manifest_version": 3,
  "name": "YouTube Doomscroll Blocker",
  "version": "1.0.0",
  "description": "Prevent YouTube Shorts scrolling and track your consumption stats",
  "permissions": [
    "storage",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*.svg", "icons/*.png", "icons/*.jpg"],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
